# Postgres connection (matches docker-compose.yml, host port 5433)
DATABASE_URL="postgresql://pilots:pilots@localhost:5433/pilots?schema=public"

# Server
PORT=4000
# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGIN="http://localhost:5173"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Where invite links point (the frontend). Used when generating invitation URLs.
APP_URL="http://localhost:5173"

# Email delivery: "console" logs emails to the terminal (default, no setup needed).
# Set to "smtp" and fill SMTP_* to send real email later.
EMAIL_TRANSPORT="console"
EMAIL_FROM="Pilot Manager <no-reply@pilots.local>"
